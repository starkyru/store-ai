{
  "name": "store-ai",
  "private": true,
  "description": "Framework-agnostic, store-agnostic AI stream state management",
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "test": "turbo run test",
    "test:watch": "turbo run test:watch",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "clean": "turbo run clean",
    "dev": "turbo run dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "publish:all": "turbo run build && pnpm -r publish --access public",
    "deploy:docs": "pnpm --filter store-ai-docs run build && rsync -avz --delete docs/site/.vitepress/dist/ ilia-root:/home/ilia/apps/store-ai-docs/",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md,yaml,yml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "turbo": "^2.4.0",
    "typescript": "^5.7.0"
  },
  "pnpm": {
    "overrides": {
      "vitepress>vite": "6.4.2",
      "vitepress>esbuild": "0.25.12"
    }
  }
}
